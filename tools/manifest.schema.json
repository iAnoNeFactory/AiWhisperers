{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AiWhisperers Module Manifest v2.0",
  "type": "object",
  "required": ["id", "name", "version", "date", "description", "type", "status", "lineage", "files", "runtime", "relations", "tags"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^_?[a-z][a-z0-9_-]*$",
      "description": "kebab-case lub snake_case, opcjonalny prefiks _ dla modułów systemowych"
    },
    "name":        { "type": "string", "minLength": 1 },
    "version":     { "type": "string", "pattern": "^\\d+\\.\\d+(\\.\\d+)?$" },
    "date":        { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "description": { "type": "string", "minLength": 1 },
    "type":        { "type": "string", "minLength": 1 },
    "status":      { "type": "string", "enum": ["incubation", "active", "mature", "dormant", "archived"] },
    "lineage": {
      "type": "object",
      "required": ["seed_session", "parent_sid", "contract_sha", "contributors"],
      "additionalProperties": false,
      "properties": {
        "seed_session": { "type": "string" },
        "parent_sid":   { "type": "string" },
        "contract_sha": { "type": "string" },
        "contributors": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["actor", "role", "chat_id"],
            "additionalProperties": false,
            "properties": {
              "actor":   { "type": "string" },
              "role":    { "type": "string" },
              "chat_id": { "type": "string" }
            }
          }
        },
        "signature": {
          "type": "object",
          "required": ["actor", "sha256"],
          "additionalProperties": false,
          "properties": {
            "actor":  { "type": "string" },
            "sha256": { "type": "string" }
          }
        }
      }
    },
    "files": {
      "type": "object",
      "required": ["entry", "docs", "components", "bootstrap", "bootstrap_sha", "entry_sha", "docs_sha"],
      "additionalProperties": false,
      "properties": {
        "entry":         { "type": "string", "minLength": 1 },
        "docs":          { "type": "string" },
        "components":    { "type": "array" },
        "bootstrap":     { "type": "string" },
        "bootstrap_sha": { "type": "string", "pattern": "^([a-f0-9]{64})?$" },
        "entry_sha":     { "type": "string", "pattern": "^([a-f0-9]{64})?$" },
        "docs_sha":      { "type": "string", "pattern": "^([a-f0-9]{64})?$" }
      }
    },
    "runtime": {
      "type": "object",
      "required": ["data_path", "io", "port", "consumers", "operator_state", "i18n"],
      "additionalProperties": false,
      "properties": {
        "data_path":      { "type": "string", "pattern": "^\\.data/.*/$|^$" },
        "io":             { "type": "array", "items": { "type": "string", "enum": ["read", "write"] } },
        "port":           { "type": "integer", "minimum": 0, "maximum": 65535 },
        "consumers":      { "type": "array", "items": { "type": "string", "enum": ["human", "ai"] } },
        "operator_state": { "type": "string" },
        "i18n": {
          "type": "object",
          "required": ["default", "available", "lang_file"],
          "additionalProperties": false,
          "properties": {
            "default":   { "type": "string" },
            "available": { "type": "array", "items": { "type": "string" } },
            "lang_file": { "type": "string" }
          }
        }
      }
    },
    "relations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "target"],
        "additionalProperties": false,
        "properties": {
          "type": {
            "type": "string",
            "enum": ["requires", "feeds", "complements", "extends", "documents", "mirrors", "used-by", "validates", "consumes"]
          },
          "target": { "type": "string" }
        }
      }
    },
    "tags": { "type": "array", "items": { "type": "string" } }
  }
}
